  "introStory": [
    {
      "type": "title",
      "text": "第二章",
      "subtitle": "四十五星衡"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「恭喜通过入门考核，新人侦探。现在，跟我上楼。」"
    },
    {
      "character": "旁白",
      "icon": "🏛️",
      "text": "你踏上旋转楼梯，来到第二层档案库。这里比一楼宽敞得多，墙上挂满了星图般的演算手稿。"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「这一层，我收藏了年轻时的全部演算手稿。核心只有一个数字——45。」"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「在4×4盘面上，每行每列每宫的总和是10。到了6×6，变成21。而标准9×9盘面呢？」"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「1+2+3+...+9=45。这是杀手数独最核心的钥匙——只要是完整的一行、一列、一宫，总和永远是45。」"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「先从6×6的小盘面练练手，熟悉『21法则』，再进入9×9的正式领域。桌上有我留下的黄铜算珠，会帮你计算。」"
    }
  ],
  "endingStory": [
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「不错，你已经掌握了45法则的基础用法。单格差值、内外笼推导，这些都是侦探的基本功。」"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「但有时候，单个笼子的信息不够。你需要观察成对的数字组合——它们像影子一样，一起出现，一起排除。」"
    },
    {
      "character": "大师手记",
      "icon": "📜",
      "text": "「带上这枚黄铜算珠，前往第三卷宗。那里的谜题，需要你学会在笼子里寻找数字的搭档。」"
    }
  ],
