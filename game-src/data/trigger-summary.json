  {
    "chapterId": 1,
    "title": "加密来信",
    "levels": [
      {
        "levelId": 102,
        "title": "第1关：数独初体验",
        "gridSize": 4,
        "difficulty": "入门",
        "teachingGoal": "认识数独的基本规则",
        "triggers": [
          {
            "id": "t101_start",
            "condition": "onLevelStart",
            "type": "freeze_mask",
            "once": true,
            "text": "灰色数字是提示。点一下这个空格，再从底部数字键里选一个填进去。",
            "targetCell": [
              0,
              2
            ]
          },
          {
            "id": "t101_fill",
            "condition": "onFirstNumberFilled",
            "type": "popup_hint",
            "once": true,
            "text": "太棒了！每行、每列、每个2x2方块里，数字1-4都不能重复哦～",
            "position": "top"
          },
          {
            "id": "t101_conflict",
            "condition": "onConflict",
            "type": "popup_hint",
            "once": false,
            "text": "这一行/列/宫里已经有这个数字了！用擦除按钮清掉，换个数字试试。",
            "position": "top"
          },
          {
            "id": "t101_half",
            "condition": "onFillCountReached",
            "type": "popup_hint",
            "once": true,
            "text": "一半完成啦！用同样的方法填完剩下的格子～",
            "position": "top",
            "count": 4
          }
        ]
      },
      {
        "levelId": 103,
        "title": "第2关：行列探索",
